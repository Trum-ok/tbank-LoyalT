CORE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tbank_loyalt
# Read-реплика для тяжёлых read-only запросов (история, аналитика).
# Пусто/не задано → весь трафик идёт в primary (безопасный fallback).
# CORE_DATABASE_REPLICA_URL=postgresql+psycopg://postgres:postgres@replica:5432/tbank_loyalt
CORE_DB_SCHEMA=core
CORE_DB_ECHO=false
CORE_DEBUG=false

# Пул соединений SQLAlchemy (тюнится по числу воркеров и max_connections БД).
CORE_DB_POOL_SIZE=20
CORE_DB_MAX_OVERFLOW=20
CORE_DB_POOL_TIMEOUT=30
CORE_DB_POOL_RECYCLE=1800

# JWT кассира (HS256). Должен совпадать с PARTNER_JWT_SECRET.
# ОБЯЗАТЕЛЬНО задать собственное значение в проде. При CORE_DEBUG=false
# сервис не стартует с публичным sentinel-секретом из репозитория.
CORE_JWT_SECRET=local-dev-shared-cashier-secret-change-me

# Kafka. Если выключена, publisher логирует события, а consumer не стартует.
# События можно эмулировать через POST /internal/events.
CORE_KAFKA_ENABLED=false
CORE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
CORE_KAFKA_GROUP_ID=core-service
CORE_KAFKA_TOPIC_CORE_EVENTS=core.events
# core.events — собственные события points.*, проецируемые в read-модель
# аналитики тем же consumer'ом (идемпотентно).
CORE_KAFKA_SUBSCRIBE_TOPICS=["partner.events", "core.events"]
