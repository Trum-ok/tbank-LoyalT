CORE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tbank_loyalt
CORE_DB_SCHEMA=core
CORE_DB_ECHO=false
CORE_DEBUG=false

# JWT кассира (HS256). Должен совпадать с PARTNER_JWT_SECRET.
CORE_JWT_SECRET=dev-tbank-loyalt-cashier-jwt-secret-change-in-prod

# Kafka. Если выключена, publisher логирует события, а consumer не стартует.
# События можно эмулировать через POST /internal/events.
CORE_KAFKA_ENABLED=false
CORE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
CORE_KAFKA_GROUP_ID=core-service
CORE_KAFKA_TOPIC_CORE_EVENTS=core.events
CORE_KAFKA_SUBSCRIBE_TOPICS=["partner.events"]
