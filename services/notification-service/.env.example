NOTIFICATION_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tbank_loyalt
NOTIFICATION_DB_SCHEMA=notification
NOTIFICATION_DB_ECHO=false
NOTIFICATION_DEBUG=false

# Kafka. При false consumer не стартует; события можно эмулировать через
# POST /internal/events.
NOTIFICATION_KAFKA_ENABLED=false
NOTIFICATION_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NOTIFICATION_KAFKA_GROUP_ID=notification-service
NOTIFICATION_KAFKA_TOPICS=["core.events","partner.events"]
