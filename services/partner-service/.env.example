PARTNER_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tbank_loyalt
PARTNER_DB_SCHEMA=partner
PARTNER_DB_ECHO=false
PARTNER_DEBUG=false

# JWT кассира (HS256). Должен совпадать с CORE_JWT_SECRET.
PARTNER_JWT_SECRET=dev-tbank-loyalt-cashier-jwt-secret-change-in-prod
PARTNER_JWT_TTL_HOURS=12

# Kafka: при false producer работает в stub-режиме (события идут в лог)
PARTNER_KAFKA_ENABLED=false
PARTNER_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PARTNER_KAFKA_TOPIC_PARTNER_EVENTS=partner.events

# MinIO / S3 для логотипов партнёров.
# S3_ENDPOINT_URL — для SDK (в docker-сети http://minio:9000).
# S3_PUBLIC_URL — то, что видит браузер и что сохраняется в logo_url.
PARTNER_S3_ENDPOINT_URL=http://localhost:9000
PARTNER_S3_PUBLIC_URL=http://localhost:9000
PARTNER_S3_ACCESS_KEY=minioadmin
PARTNER_S3_SECRET_KEY=minioadmin
PARTNER_S3_REGION=us-east-1
PARTNER_S3_BUCKET=partner-logos
PARTNER_LOGO_MAX_BYTES=2097152
